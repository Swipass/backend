// =============================================================
// SWIPASS v0.2 — Database Schema (multi‑step support)
// =============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Admin users (auto-seeded on startup) ─────────────────────
model Admin {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String   @default("Admin")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("admins")
}

// ── Quote: priced route from LI.FI ───────────────────────────
model Quote {
  id            String      @id
  fromChainId   Int
  toChainId     Int
  fromChain     String
  toChain       String
  fromToken     String      // symbol, e.g. "USDC"
  toToken       String
  fromTokenAddr String      // contract address
  toTokenAddr   String
  fromAmount    String      // raw amount (wei / lamports)
  toAmount      String      // expected output after fee
  toAmountMin   String      // minimum output (slippage)
  feePct        Float       // swipass fee percentage
  feeAmount     String      // fee in output token units
  estimatedTime Int         // seconds
  aggregator    String      @default("lifi")
  routeData     Json        // full LI.FI route for execution
  expiresAt     DateTime
  status        QuoteStatus @default(PENDING)
  createdAt     DateTime    @default(now())

  executions Execution[]

  @@index([createdAt])
  @@index([fromChain, toChain])
  @@map("quotes")
}

enum QuoteStatus {
  PENDING
  EXECUTED
  EXPIRED
}

// ── Execution: a user-initiated bridge transaction ───────────
model Execution {
  id               String          @id @default(uuid())
  quoteId          String
  quote            Quote           @relation(fields: [quoteId], references: [id])
  userAddress      String          // who signed the tx
  recipientAddress String          // who receives funds (may differ)
  currentStepIndex Int             @default(0)   // index of the step we are on
  status           ExecutionStatus @default(PENDING)
  errorMessage     String?
  completedAt      DateTime?
  durationMs       Int?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  steps Step[]

  @@index([userAddress])
  @@index([status])
  @@index([createdAt])
  @@map("executions")
}

enum ExecutionStatus {
  PENDING   // waiting for user to sign next step
  BRIDGING  // at least one step submitted, not finished
  SUCCESS   // all steps done
  FAILED    // a step failed
}

// ── Individual step inside an execution (approval, swap, cross) ──
model Step {
  id            String      @id @default(cuid())
  executionId   String
  execution     Execution   @relation(fields: [executionId], references: [id], onDelete: Cascade)
  stepIndex     Int         // 0, 1, 2...
  type          String      // "approval", "swap", "cross"
  status        StepStatus  @default(PENDING)
  txHash        String?     // hash of the submitted transaction for this step
  transactionRequest Json?   // the tx object LI.FI gave us (stored as JSON)
  createdAt     DateTime    @default(now())
  completedAt   DateTime?
  errorMessage  String?

  @@unique([executionId, stepIndex])
  @@map("steps")
}

enum StepStatus {
  PENDING      // waiting for user to sign & send
  SUBMITTED    // tx hash received, waiting for confirmation
  CONFIRMED    // tx confirmed on chain (but next step not yet started)
  COMPLETED    // step fully done (if swap/cross) or just confirmed if approval
  FAILED
}

// ── Fee configuration (editable from admin) ──────────────────
model FeeConfig {
  id           String   @id @default(uuid())
  feePct       Float    @default(0.003)  // 0.3%
  minFeePct    Float    @default(0.001)  // 0.1%
  maxFeePct    Float    @default(0.005)  // 0.5%
  isActive     Boolean  @default(true)
  updatedAt    DateTime @updatedAt
  createdAt    DateTime @default(now())

  @@map("fee_configs")
}

// ── Bridge on/off switch (admin can disable a bridge) ────────
model BridgeConfig {
  id        String   @id @default(uuid())
  name      String   @unique   // e.g. "across", "stargate"
  isEnabled Boolean  @default(true)
  notes     String?
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@map("bridge_configs")
}