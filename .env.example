# ============================================================
# SWIPASS BACKEND v0.1 — Environment Variables
# Copy this file to .env and fill in all values.
# See GUIDE.md for step-by-step instructions on each variable.
# ============================================================

# ── Server ────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
HOST=0.0.0.0
API_URL=http://localhost:4000

# ── Database ──────────────────────────────────────────────────
# Local Docker: postgresql://postgres:password@localhost:5432/izipass
# Railway / Render / Supabase: copy the connection string from their dashboard
DATABASE_URL=postgresql://postgres:password@localhost:5432/izipass

# ── Redis (optional — caching gracefully disabled if absent) ──
# Local Docker: redis://localhost:6379
# Upstash free tier: copy Redis URL from Upstash dashboard
REDIS_URL=redis://localhost:6379

# ── JWT ───────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
# NEVER commit the real value to git
JWT_SECRET=change_me_to_a_long_random_secret_before_deploying

# ── Admin account (auto-created on first startup) ─────────────
ADMIN_EMAIL=admin@swipass.dev
ADMIN_PASSWORD=Admin@123456

# ── LI.FI Aggregator ──────────────────────────────────────────
# Get API key at: https://apidocs.li.fi/  → Dashboard → API Keys
# Leave blank to use the public (rate-limited) tier
LIFI_API_KEY=
LIFI_API_URL=https://li.quest/v1

# ── Frontend URL (for CORS + tracking URLs) ───────────────────
FRONTEND_URL=http://localhost:3000

# ── Rate limiting ─────────────────────────────────────────────
RATE_LIMIT_MAX=60

# ── Logging ───────────────────────────────────────────────────
# debug | info | warn | error
LOG_LEVEL=info
